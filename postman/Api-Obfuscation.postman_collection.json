                  "  const enc = CryptoJS.AES.encrypt(src, key, { iv: iv, mode: CryptoJS.mode.CBC, padding: CryptoJS.pad.Pkcs7 });",
                  "  const bx = CryptoJS.enc.Base64.stringify(enc.ciphertext);",
                  "  const signPayload = bx + '|' + ts + '|' + nonce;",
                  "  const sg = CryptoJS.HmacSHA256(signPayload, signKey).toString(CryptoJS.enc.Hex);",
                  "  pm.request.body.raw = JSON.stringify({ [pf]: bx, [sf]: sg, [tf]: ts, [nf]: nonce });",
                  "} else {",
                  "  pm.request.body.raw = JSON.stringify(innerObj);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "raw": "{ \"pg\": \"1\", \"sz\": \"10\", \"kw\": \"\" }",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/content/list",
            "description": "中间件将 `pg→page`，`sz→limit`，`kw→keywords`（与 config 中 10001 一致）。"
          },
          "response": []
        }
      ]
    },
